ANTHROPIC_API_KEY=<your-anthropic-api-key>

# PostgreSQL — primary data source
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=

# Palantir Foundry — optional, used if Foundry IP allowlist permits
FOUNDRY_HOST=https://nshackathon.palantirfoundry.com
FOUNDRY_TOKEN=<your-foundry-bearer-token>
FOUNDRY_ONTOLOGY_RID=
FOUNDRY_DATASET_TELEMETRY_RID=
FOUNDRY_DATASET_MISSIONS_RID=
